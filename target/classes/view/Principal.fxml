<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="750" prefWidth="1100" spacing="0" styleClass="root-container" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="controller.PrincipalController">

    <!-- Barra superior -->
    <HBox alignment="CENTER_RIGHT" spacing="20" styleClass="barra-top">
        <padding><Insets bottom="8" left="20" right="20" top="8" /></padding>
        <Label fx:id="lblAsesor" styleClass="label-asesor" HBox.hgrow="ALWAYS" />
        <Button onAction="#onCerrarSesion" styleClass="btn-peligro" text="Cerrar Sesión" />
    </HBox>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ===================== TAB: NUEVA ORDEN ===================== -->
        <Tab text="Nueva Orden Médica">
            <ScrollPane fitToWidth="true">
                <VBox spacing="15" styleClass="tab-content">
                    <padding><Insets bottom="20" left="20" right="20" top="15" /></padding>

                    <!-- Búsqueda de paciente -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                        <Label styleClass="card-titulo" text="1. Buscar Paciente" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label styleClass="label-campo" text="Cédula del paciente:" />
                            <TextField fx:id="txtCedulaPaciente" prefWidth="200" promptText="Número de cédula" styleClass="campo-texto" />
                            <Button onAction="#onBuscarPaciente" styleClass="btn-primario" text="Buscar" />
                        </HBox>

                        <!-- Info del paciente (visible tras búsqueda exitosa) -->
                        <VBox fx:id="panelInfoPaciente" spacing="6" styleClass="panel-info-paciente">
                            <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
                            <Label styleClass="label-seccion" text="Paciente encontrado:" />
                            <HBox spacing="30">
                                <VBox spacing="3">
                                    <Label styleClass="label-campo" text="Nombre:" />
                                    <Label fx:id="lblNombrePac" styleClass="label-dato" />
                                </VBox>
                                <VBox spacing="3">
                                    <Label styleClass="label-campo" text="Edad:" />
                                    <Label fx:id="lblEdadPac" styleClass="label-dato" />
                                </VBox>
                                <VBox spacing="3">
                                    <Label styleClass="label-campo" text="Sexo:" />
                                    <Label fx:id="lblSexoPac" styleClass="label-dato" />
                                </VBox>
                                <VBox spacing="3">
                                    <Label styleClass="label-campo" text="Plan:" />
                                    <Label fx:id="lblPlanPac" styleClass="label-dato" />
                                </VBox>
                                <VBox spacing="3">
                                    <Label styleClass="label-campo" text="Estado:" />
                                    <Label fx:id="lblEstadoPac" styleClass="label-dato" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Códigos CIE-10 y CUPS -->
                    <HBox spacing="15">

                        <!-- CIE-10 -->
                        <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                            <Label styleClass="card-titulo" text="2. Código CIE-10 (Diagnóstico)" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <TextField fx:id="txtCie" prefWidth="120" promptText="Ej: H25" styleClass="campo-texto" />
                                <Button onAction="#onValidarCie" styleClass="btn-secundario" text="Validar" />
                            </HBox>
                            <Label fx:id="lblDescCie" styleClass="label-descripcion" wrapText="true" />
                            <Label fx:id="lblEspecialidadCie" styleClass="label-especialidad" />

                            <Label styleClass="label-campo" text="Sugerencias de CUPS:" />
                            <ListView fx:id="listaSugerenciasCups" onMouseClicked="#onSugerenciaSeleccionada" prefHeight="130" styleClass="lista-sugerencias" />
                        </VBox>

                        <!-- CUPS -->
                        <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                            <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                            <Label styleClass="card-titulo" text="3. Código CUPS (Procedimiento)" />
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <TextField fx:id="txtCups" prefWidth="140" promptText="Ej: 200801" styleClass="campo-texto" />
                                <Button onAction="#onValidarCups" styleClass="btn-secundario" text="Validar" />
                            </HBox>
                            <Label fx:id="lblDescCups" styleClass="label-descripcion" wrapText="true" />
                            <Label fx:id="lblPrecioCups" styleClass="label-precio" />

                            <Label styleClass="label-campo" text="Cantidad:" />
                            <TextField fx:id="txtCantidad" prefWidth="180" promptText="Cantidad de procedimientos" styleClass="campo-texto" />

                            <Button onAction="#onAgregarProcedimiento" prefWidth="200" styleClass="btn-agregar" text="+ Agregar a la orden" />
                        </VBox>
                    </HBox>

                    <!-- Institución y médico -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                        <Label styleClass="card-titulo" text="4. Institución y Médico" />
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <VBox spacing="5">
                                <Label styleClass="label-campo" text="Institución:" />
                                <ComboBox fx:id="cbInstitucion" prefWidth="280" promptText="Primero valide un CIE-10" styleClass="combo-box" />
                            </VBox>
                            <VBox spacing="5">
                                <Label styleClass="label-campo" text="Médico Asignado:" />
                                <HBox alignment="CENTER_LEFT" spacing="8">
                                    <TextField fx:id="txtMedicoSeleccionado" editable="false" prefWidth="240" promptText="Sin seleccionar" styleClass="campo-texto" />
                                    <Button onAction="#onSeleccionarMedico" styleClass="btn-secundario" text="Seleccionar Médico" />
                                </HBox>
                                <Label fx:id="lblIdMedico" styleClass="label-campo" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- Tabla de procedimientos -->
                    <VBox spacing="8" styleClass="card">
                        <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                        <HBox alignment="CENTER_LEFT" spacing="20">
                            <Label styleClass="card-titulo" text="5. Procedimientos en la Orden" HBox.hgrow="ALWAYS" />
                            <Button onAction="#onEliminarProcedimiento" styleClass="btn-peligro" text="Eliminar seleccionado" />
                        </HBox>

                        <TableView fx:id="tablaProcs" prefHeight="160">
                            <columns>
                                <TableColumn fx:id="colCups" prefWidth="100" text="CUPS" />
                                <TableColumn fx:id="colCie" prefWidth="80" text="CIE-10" />
                                <TableColumn fx:id="colDescProc" prefWidth="300" text="Descripción" />
                                <TableColumn fx:id="colCantidad" prefWidth="80" text="Cantidad" />
                                <TableColumn fx:id="colValor" prefWidth="100" text="Valor Unit." />
                                <TableColumn fx:id="colSubtotal" prefWidth="100" text="Subtotal" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <Label fx:id="lblTotal" styleClass="label-total" text="Total: $0" />
                            <Button onAction="#onRegistrarOrden" styleClass="btn-primario-grande" text="REGISTRAR ORDEN" />
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </Tab>

        <!-- ===================== TAB: HISTORIAL ===================== -->
        <Tab text="Historial de Órdenes">
            <VBox spacing="12" styleClass="tab-content">
                <padding><Insets bottom="20" left="20" right="20" top="15" /></padding>

                <VBox spacing="8" styleClass="card">
                    <padding><Insets bottom="12" left="15" right="15" top="12" /></padding>
                    <Label styleClass="card-titulo" text="Historial de Órdenes" />
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="label-campo" text="Filtrar por cédula:" />
                        <TextField fx:id="txtFiltroHistorial" prefWidth="200" promptText="Cédula del paciente" styleClass="campo-texto" />
                        <Button onAction="#onFiltrarHistorial" styleClass="btn-secundario" text="Filtrar" />
                        <Button onAction="#onRefrescarHistorial" styleClass="btn-secundario" text="Mostrar Todos" />
                    </HBox>
                </VBox>

                <TableView fx:id="tablaHistorial" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colRadicado" prefWidth="90" text="Radicado" />
                        <TableColumn fx:id="colPaciente" prefWidth="200" text="Paciente" />
                        <TableColumn fx:id="colFecha" prefWidth="100" text="Fecha" />
                        <TableColumn fx:id="colEspecialidad" prefWidth="130" text="Especialidad" />
                        <TableColumn fx:id="colInstitucion" prefWidth="200" text="Institución" />
                        <TableColumn fx:id="colTotal" prefWidth="100" text="Total" />
                        <TableColumn fx:id="colEstado" prefWidth="100" text="Estado" />
                        <TableColumn fx:id="colAsesorAccion" prefWidth="220" text="Asesor" />
                    </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#onModificarOrden" styleClass="btn-primario" text="Modificar Orden Seleccionada" />
                    <Button onAction="#onCancelarOrden" styleClass="btn-peligro" text="Cancelar Orden Seleccionada" />
                </HBox>
            </VBox>
        </Tab>

    </TabPane>
</VBox>
